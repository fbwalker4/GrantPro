# GrantPro Environment Variables
# Copy this file to .env and fill in your values
# All GP_ prefixed vars are for the GrantPro application

# Required — Supabase Postgres
GP_DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres
GP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
GP_SUPABASE_KEY=your_supabase_service_role_key

# Required — Google AI (Gemini)
GP_GOOGLE_API_KEY=your_google_api_key

# Required — Flask Secret Key
GP_SECRET_KEY=your_random_secret_key_here

# Payments — Stripe (required for paid features)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_5_PRICE_ID=price_...
STRIPE_ENTERPRISE_10_PRICE_ID=price_...
STRIPE_ENTERPRISE_UNLIMITED_PRICE_ID=price_...

# Optional — Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=Grant Pro <noreply@grantpro.org>
FROM_NAME=Grant Pro

# Optional — App URL
APP_URL=http://localhost:5001
BASE_URL=http://localhost:5001
