# ============ Flask ============
SECRET_KEY=change-me-to-a-random-hex-string
HTTPS=false                          # Set to "true" in production to enable secure cookies

# ============ App URL ============
APP_URL=http://localhost:5001        # Base URL used for Stripe redirect URLs and emails
BASE_URL=http://localhost:5001       # Base URL used by the email system

# ============ Stripe Payments ============
STRIPE_API_KEY=sk_test_...           # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...     # Stripe webhook signing secret
STRIPE_MONTHLY_PRICE_ID=price_...   # Stripe Price ID for monthly plan ($19.95/mo)
STRIPE_ANNUAL_PRICE_ID=price_...    # Stripe Price ID for annual plan ($199/yr)
STRIPE_ENTERPRISE_5_PRICE_ID=price_...       # Stripe Price ID for Enterprise 5 ($44.95/mo)
STRIPE_ENTERPRISE_10_PRICE_ID=price_...      # Stripe Price ID for Enterprise 10 ($74.95/mo)
STRIPE_ENTERPRISE_UNLIMITED_PRICE_ID=price_... # Stripe Price ID for Enterprise Unlimited ($99.95/mo)

# ============ Google AI (Gemini) ============
GOOGLE_API_KEY=AIza...               # Google Generative AI API key for grant drafting

# ============ Email (Resend) ============
RESEND_API_KEY=re_...                # Resend API key for transactional email
FROM_EMAIL=Grant Writer Pro <noreply@yourdomain.com>
FROM_NAME=Grant Writer Pro

# ============ Database (Supabase Postgres - production) ============
# Leave blank to use local SQLite for development.
# GP- prefix keeps these separate on a shared Vercel account.
GP-SUPABASE_URL=                     # e.g. https://xxxx.supabase.co
GP-SUPABASE_KEY=                     # Supabase service-role key
GP-DATABASE_URL=                     # Postgres pooler URL, e.g. postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
